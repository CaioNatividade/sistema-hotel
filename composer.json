{
    "name": "hotel/reservas",
    "description": "Sistema de Reservas de Hotel - Projeto Final",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "classmap": [
            "src/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "HotelReservas\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit tests --testdox"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
